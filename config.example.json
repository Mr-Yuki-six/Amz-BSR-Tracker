{
    // === 核心业务配置 ===
    "target_category": "PlayStation 5 Consoles",       // 重点监控的小类目名称（须与亚马逊页面显示完全一致）

    // === 爬虫性能配置 ===
    "max_workers": 5,                     // 并发线程数。建议范围 3-8，过高会导致被封 IP 或本地 CPU 负载过高
    "retry_times": 3,                     // 遇到网络波动、抓取失败或被拦截时的自动重试次数

    // === 自动化行为配置 ===
    "scroll_steps": 3,                    // 页面向下滚动的次数。增加此值可确保懒加载的 BSR 表格完全渲染
    "wait_before_action": 1.0,            // 模拟真人在页面上的停顿时间（秒），降低被识别为机器人的风险

    // === 调试与容错配置 ===
    "debug_wait_time": 60,                // 使用 --debug 参数运行时，抓取完一个 ASIN 后浏览器保留窗口的时间（秒）
    "save_error_screenshot": true,        // 当抓取失败（未找到排名）时，是否自动保存页面截图到 debug 文件夹
    "headless_img_disabled": true         // 无头模式下是否禁用图片加载。开启可极大提升抓取速度并节省流量
}